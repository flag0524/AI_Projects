# LaonGEN 환경변수 예시 — 복사해서 .env 로 사용
# (.env 는 커밋하지 말 것)

# ── 생성형 백엔드 선택 ─────────────────────────────────────────
# auto       : higgsfield → hf → replicate → 절차적 (캐스케이드)
# higgsfield : higgsfield → hf → replicate → 절차적
# hf         : HuggingFace Leffa → 절차적
# replicate  : Replicate IDM-VTON → 절차적
GEN_BACKEND=hf

# ── Higgsfield (생성형, MCP 서버 채널) ─────────────────────────
# 전송은 MCP 서버(JSON-RPC over streamable HTTP, Bearer 인증).
# REST 호스트(api.higgsfield.ai)는 522로 미동작하여 MCP로 통합 (2026-06-09).
# 키 없으면 자동으로 다음 백엔드로 폴백.
HIGGSFIELD_API_KEY=
# MCP 엔드포인트 (기본값 사용 시 비워둬도 됨)
HIGGSFIELD_MCP_URL=https://mcp.higgsfield.ai/mcp
# 생성 모델 id
HIGGSFIELD_TRYON_MODEL=nano_banana_pro
# 사내 프록시 SSL 가로채기 환경의 루트 CA 경로 (선택)
# HIGGSFIELD_CA_BUNDLE=C:\path\to\corp-ca.pem

# ── HuggingFace Leffa (무료, ZeroGPU) ──────────────────────────
HF_TOKEN=
# HF_TRYON_SPACE=franciszzj/Leffa

# ── Replicate IDM-VTON (유료) ──────────────────────────────────
REPLICATE_API_TOKEN=
# REPLICATE_CA_BUNDLE=C:\path\to\corp-ca.pem
